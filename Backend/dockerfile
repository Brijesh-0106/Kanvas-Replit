FROM node:20.20.0-alpine
WORKDIR /app

ARG AUTO_SCALING_GROUP_NAME
ARG ACC_KEY_ID
ARG SECRET_ACC_KEY
ARG PORT
ARG DATABASE_URL
ARG SECRET_KEY
ARG GOOGLE_SECRET
ARG GRACE_PERIOD
ARG GOOGLE_CLIENT_ID

ENV AUTO_SCALING_GROUP_NAME=$AUTO_SCALING_GROUP_NAME
ENV ACC_KEY_ID=$ACC_KEY_ID
ENV SECRET_ACC_KEY=$SECRET_ACC_KEY
ENV PORT=$PORT
ENV DATABASE_URL=$DATABASE_URL
ENV SECRET_KEY=$SECRET_KEY
ENV GOOGLE_SECRET=$GOOGLE_SECRET
ENV GRACE_PERIOD=$GRACE_PERIOD
ENV GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID

COPY ./package.json ./package.json
COPY ./package-lock.json ./package-lock.json
RUN npm install

COPY prisma ./prisma
RUN npx prisma generate

COPY . .
RUN npm run prebuild
EXPOSE 9092
CMD ["npm","run","start"]